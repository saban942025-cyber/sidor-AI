{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A logistics order for H. Saban Building Materials.",
      "type": "object",
      "properties": {
        "driver": { "type": "string", "enum": ["חכמת", "עלי"] },
        "client": { "type": "string" },
        "deliveryType": { "type": "string" },
        "warehouse": { "type": "string", "enum": ["התלמיד", "החרש"] },
        "status": { "type": "string", "enum": ["ממתין", "בביצוע", "הושלם", "בוטל"] },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" },
        "orderIndex": { "type": "integer" },
        "priority": { "type": "string", "enum": ["normal", "high"] },
        "orderNumber": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "deliveryTime": { "type": "string" },
        "predictedETA": { "type": "string" },
        "predictedMinutes": { "type": "integer" },
        "completedAt": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "required": ["driver", "client", "deliveryType", "warehouse", "status", "createdAt", "orderIndex"]
    },
    "Message": {
      "title": "ChatMessage",
      "description": "A message in the AI chat with Rami.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "A record of a change made to an order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "integer" },
        "action": { "type": "string" },
        "changes": { "type": "object" }
      },
      "required": ["userId", "userEmail", "timestamp", "action"]
    }
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collections of daily logistics orders."
    },
    "/orders/{orderId}/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit logs for a specific order."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages for a specific chat session."
    }
  }
}
